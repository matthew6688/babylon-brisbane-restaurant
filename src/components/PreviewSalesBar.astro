---
import { loadCheckoutArtifact } from '../lib/restaurantArtifacts';

const checkout = loadCheckoutArtifact();
const tiers = checkout.tiers || [];
const oneTime = tiers.find((tier: any) => tier.id === 'one_time') || tiers[0];
const yearly = tiers.find((tier: any) => tier.id === 'yearly_maintenance') || tiers[1];
const hasSalesBar = Boolean(oneTime?.purchaseUrl || yearly?.purchaseUrl || checkout.feedbackUrl);
---

{hasSalesBar && (
  <aside class="preview-sales-bar" aria-label="Preview claim actions">
    <div class="preview-sales-inner">
      <div class="preview-sales-copy">
        <strong>Preview ready</strong>
        <span>Claim, revise, or maintain this site</span>
      </div>
      <nav class="preview-sales-actions" aria-label="Preview purchase and feedback links">
        {oneTime?.purchaseUrl && (
          <a class="preview-sales-button preview-sales-primary" href={oneTime.purchaseUrl} target="_blank">
            <span>Claim ${oneTime.amount}</span>
            <small>3 revisions</small>
          </a>
        )}
        {yearly?.purchaseUrl && (
          <a class="preview-sales-button" href={yearly.purchaseUrl} target="_blank">
            <span>${yearly.amount}/yr</span>
            <small>monthly care</small>
          </a>
        )}
        {checkout.feedbackUrl && (
          <a class="preview-sales-link" href={checkout.feedbackUrl} target="_blank">Request changes</a>
        )}
      </nav>
    </div>
  </aside>
)}

<style>
  :global(body:has(.preview-sales-bar)) {
    padding-bottom: 76px;
  }

  .preview-sales-bar {
    position: fixed;
    z-index: 60;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 0.55rem;
    background: transparent;
    color: #17120e;
    pointer-events: none;
  }

  .preview-sales-inner {
    display: flex;
    max-width: 900px;
    min-height: 56px;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin: 0 auto;
    border: 1px solid rgba(23, 18, 14, 0.12);
    border-radius: 999px;
    padding: 0.46rem;
    background: rgba(255, 253, 248, 0.92);
    backdrop-filter: blur(18px);
    box-shadow: 0 18px 55px rgba(23, 18, 14, 0.2);
    pointer-events: auto;
  }

  .preview-sales-copy {
    display: grid;
    min-width: 0;
    gap: 0.15rem;
  }

  .preview-sales-copy strong {
    font-size: 0.9rem;
    font-weight: 900;
    line-height: 1.1;
  }

  .preview-sales-copy span {
    color: #6d6258;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .preview-sales-actions {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.45rem;
  }

  .preview-sales-button,
  .preview-sales-link {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
  }

  .preview-sales-button {
    gap: 0.32rem;
    border: 1px solid rgba(23, 18, 14, 0.16);
    padding: 0.45rem 0.82rem;
    background: #17120e;
    color: #fffdf8;
  }

  .preview-sales-primary {
    background: #b9802f;
    border-color: #b9802f;
  }

  .preview-sales-button span {
    font-size: 0.86rem;
    font-weight: 950;
    line-height: 1;
  }

  .preview-sales-button small {
    font-size: 0.66rem;
    font-weight: 850;
    line-height: 1;
  }

  .preview-sales-link {
    min-height: 38px;
    padding: 0.42rem 0.6rem;
    color: #17120e;
    font-size: 0.76rem;
    font-weight: 900;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 680px) {
    :global(body:has(.preview-sales-bar)) {
      padding-bottom: 104px;
    }

    .preview-sales-inner {
      min-height: 54px;
      align-items: center;
      gap: 0.55rem;
      border-radius: 999px;
      overflow: hidden;
    }

    .preview-sales-copy {
      display: none;
    }

    .preview-sales-actions {
      overflow-x: auto;
      width: auto;
      max-width: 100vw;
      padding-bottom: 0.1rem;
    }

    .preview-sales-button {
      flex: 0 0 auto;
      min-height: 40px;
      padding-inline: 0.76rem;
    }

    .preview-sales-button small {
      display: none;
    }

    .preview-sales-link {
      flex: 0 0 auto;
      min-height: 40px;
      padding-inline: 0.75rem;
    }
  }
</style>
