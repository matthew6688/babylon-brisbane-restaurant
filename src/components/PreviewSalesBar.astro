---
import { loadCheckoutArtifact } from '../lib/restaurantArtifacts';

const checkout = loadCheckoutArtifact();
const tiers = checkout.tiers || [];
const oneTime = tiers.find((tier: any) => tier.id === 'one_time') || tiers[0];
const yearly = tiers.find((tier: any) => tier.id === 'yearly_maintenance') || tiers[1];
const hasSalesBar = Boolean(oneTime?.purchaseUrl || yearly?.purchaseUrl || checkout.feedbackUrl);
const hidden = checkout.hiddenFields || {};
const clientSlug = hidden.client_slug || checkout.clientSlug || '';
const repo = hidden.repo || '';
const previewUrl = hidden.preview_url || '';
const infoParams = new URLSearchParams({
  client_slug: clientSlug,
  repo,
  preview_url: previewUrl,
});
const faqUrl = `/demo-faq?${infoParams.toString()}`;
---

{hasSalesBar && (
  <aside
    class="preview-sales-bar"
    aria-label="Preview claim and order actions"
    data-preview-sales-bar
    data-client-slug={clientSlug}
    data-repo={repo}
    data-preview-url={previewUrl}
  >
    <div class="preview-sales-inner">
      <div class="preview-sales-copy">
        <span class="preview-sales-brand">ProfitsLocal</span>
        <div>
          <strong data-sales-title>Website preview ready</strong>
          <span data-sales-subtitle>Review the offer, then claim this site</span>
        </div>
      </div>
      <nav class="preview-sales-actions" aria-label="Preview purchase and feedback links">
        <a class="preview-sales-link" href={faqUrl} data-sales-mode>How it works</a>
        {oneTime?.purchaseUrl && (
          <a class="preview-sales-button preview-sales-primary" href={oneTime.purchaseUrl} target="_blank" data-sales-mode>
            <span>Claim ${oneTime.amount}</span>
            <small>3 revisions</small>
          </a>
        )}
        {yearly?.purchaseUrl && (
          <a class="preview-sales-button" href={yearly.purchaseUrl} target="_blank" data-sales-mode>
            <span>${yearly.amount}/yr</span>
            <small>monthly care</small>
          </a>
        )}
        <a class="preview-sales-button preview-sales-primary is-hidden" href="/approve" data-order-mode data-approve-link>
          <span>Approve site</span>
          <small>publish live</small>
        </a>
        <a class="preview-sales-button is-hidden" href="/revise" data-order-mode data-revise-link>
          <span>Request revision</span>
          <small data-revision-usage>check quota</small>
        </a>
        <a class="preview-sales-link is-hidden" href="/domain-setup" data-order-mode data-domain-link>Domain setup</a>
        <a class="preview-sales-link is-hidden" href="/checkout?tier=extra_revision" data-order-mode data-extra-link>Buy extra revision</a>
        {checkout.feedbackUrl && (
          <a class="preview-sales-link" href={checkout.feedbackUrl} target="_blank" data-sales-mode>Request changes</a>
        )}
      </nav>
    </div>
  </aside>
)}

<script>
  const bar = document.querySelector('[data-preview-sales-bar]');
  if (bar) {
    const params = new URLSearchParams(window.location.search);
    const orderId = params.get('order_id') || params.get('session_id') || '';
    const email = params.get('email') || '';
    const clientSlug = bar.getAttribute('data-client-slug') || params.get('client_slug') || '';
    const repo = bar.getAttribute('data-repo') || params.get('repo') || '';
    const previewUrl = bar.getAttribute('data-preview-url') || window.location.origin;
    if (orderId && email) {
      const shared = new URLSearchParams({
        order_id: orderId,
        email,
        client_slug: clientSlug,
        repo,
        preview_url: previewUrl,
      });
      bar.querySelectorAll('[data-sales-mode]').forEach((element) => element.classList.add('is-hidden'));
      bar.querySelectorAll('[data-order-mode]').forEach((element) => element.classList.remove('is-hidden'));
      const title = bar.querySelector('[data-sales-title]');
      const subtitle = bar.querySelector('[data-sales-subtitle]');
      const approve = bar.querySelector('[data-approve-link]');
      const revise = bar.querySelector('[data-revise-link]');
      const extra = bar.querySelector('[data-extra-link]');
      const domain = bar.querySelector('[data-domain-link]');
      if (title) title.textContent = 'Review controls';
      if (subtitle) subtitle.textContent = 'Approve or request changes from this dev preview';
      if (approve) approve.setAttribute('href', `/approve?${shared.toString()}`);
      if (revise) revise.setAttribute('href', `/revise?${shared.toString()}`);
      if (domain) domain.setAttribute('href', `/domain-setup?${shared.toString()}`);
      if (extra) {
        const extraParams = new URLSearchParams(shared);
        extraParams.set('tier', 'extra_revision');
        extra.setAttribute('href', `/checkout?${extraParams.toString()}`);
      }
      fetch('/api/order-status/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ order_id: orderId, email, client_slug: clientSlug, repo }),
      })
        .then((response) => (response.ok ? response.json() : null))
        .then((data) => {
          const usage = bar.querySelector('[data-revision-usage]');
          if (!usage || !data?.revision) return;
          usage.textContent = `${data.revision.used}/${data.revision.limit} used`;
        })
        .catch(() => {});
    }
  }
</script>

<style>
  :global(body:has(.preview-sales-bar)) {
    padding-bottom: 88px;
  }

  .preview-sales-bar {
    position: fixed;
    z-index: 80;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 0.85rem;
    background: transparent;
    color: #17191c;
    pointer-events: none;
  }

  .preview-sales-inner {
    display: flex;
    max-width: 1040px;
    min-height: 64px;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 auto;
    border: 1px solid rgba(23, 25, 28, 0.12);
    border-radius: 26px;
    padding: 0.62rem;
    background:
      linear-gradient(135deg, rgba(255, 246, 236, 0.96), rgba(255, 252, 247, 0.94)),
      #fff6ec;
    backdrop-filter: blur(20px);
    box-shadow:
      0 20px 70px rgba(23, 25, 28, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.75);
    pointer-events: auto;
  }

  .preview-sales-copy {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.85rem;
    padding-left: 0.55rem;
  }

  .preview-sales-brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    border-right: 1px solid rgba(23, 25, 28, 0.14);
    padding-right: 0.9rem;
    color: #17191c;
    font-family: Playfair Display, Georgia, serif;
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0;
  }

  .preview-sales-copy strong {
    display: block;
    color: #17191c;
    font-family: Inter, Manrope, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.88rem;
    font-weight: 850;
    line-height: 1.1;
  }

  .preview-sales-copy span {
    color: #5e6268;
    display: block;
    font-family: Inter, Manrope, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 720;
    line-height: 1.25;
  }

  .preview-sales-actions {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.45rem;
  }

  .preview-sales-button,
  .preview-sales-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    font-family: Inter, Manrope, ui-sans-serif, system-ui, sans-serif;
    text-decoration: none;
    white-space: nowrap;
  }

  .is-hidden {
    display: none !important;
  }

  .preview-sales-button {
    gap: 0.32rem;
    border: 1px solid rgba(23, 25, 28, 0.14);
    padding: 0.48rem 0.9rem;
    background: #17191c;
    color: #fffcf7;
    box-shadow: 0 10px 24px rgba(23, 25, 28, 0.14);
  }

  .preview-sales-primary {
    background: #ff5a3d;
    border-color: #ff5a3d;
    color: #17191c;
    box-shadow: 0 12px 30px rgba(255, 90, 61, 0.28);
  }

  .preview-sales-button span {
    font-size: 0.86rem;
    font-weight: 900;
    line-height: 1;
  }

  .preview-sales-button small {
    font-size: 0.66rem;
    font-weight: 800;
    line-height: 1;
    opacity: 0.86;
  }

  .preview-sales-link {
    min-height: 42px;
    border: 1px solid transparent;
    padding: 0.42rem 0.7rem;
    color: #17191c;
    font-size: 0.76rem;
    font-weight: 850;
    text-decoration: none;
  }

  .preview-sales-link:hover {
    border-color: rgba(23, 25, 28, 0.13);
    background: rgba(255, 252, 247, 0.82);
  }

  @media (max-width: 680px) {
    :global(body:has(.preview-sales-bar)) {
      padding-bottom: 96px;
    }

    .preview-sales-bar {
      padding: 0.62rem;
    }

    .preview-sales-inner {
      min-height: 58px;
      align-items: center;
      gap: 0.55rem;
      border-radius: 22px;
      overflow: hidden;
    }

    .preview-sales-copy {
      display: none;
    }

    .preview-sales-actions {
      overflow-x: auto;
      width: auto;
      max-width: 100vw;
      padding-bottom: 0.1rem;
    }

    .preview-sales-button {
      flex: 0 0 auto;
      min-height: 42px;
      padding-inline: 0.76rem;
    }

    .preview-sales-button small {
      display: none;
    }

    .preview-sales-button[data-order-mode] {
      gap: 0.28rem;
    }

    .preview-sales-button[data-order-mode] small {
      display: inline;
      max-width: 4.8rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .preview-sales-link {
      flex: 0 0 auto;
      min-height: 40px;
      padding-inline: 0.75rem;
    }
  }
</style>
