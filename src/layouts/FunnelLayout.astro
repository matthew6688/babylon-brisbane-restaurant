---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  businessName?: string;
}

const {
  title,
  description = 'ProfitsLocal website preview support',
  businessName = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
</head>
<body class="profitslocal-funnel">
  <header class="pl-header">
    <a class="pl-brand" href="/">
      <span>ProfitsLocal</span>
      <small>website preview desk</small>
    </a>
    <nav aria-label="Preview support">
      <a href="/demo-faq">How it works</a>
      <a href="/checkout">Checkout</a>
      <a href="/domain-help">Domain</a>
      <a href="/revise">Revision</a>
    </nav>
  </header>

  <main>
    {businessName && <p class="pl-project-label">Project: {businessName}</p>}
    <slot />
  </main>

  <footer class="pl-footer">
    <span>ProfitsLocal</span>
    <p>Preview, payment, revision, approval, and domain launch support for small-business websites.</p>
  </footer>
</body>
</html>

<style is:global>
  .profitslocal-funnel {
    min-height: 100vh;
    margin: 0;
    background:
      linear-gradient(180deg, rgba(185, 128, 47, 0.08), transparent 34rem),
      #fbfaf7;
    color: #17120e;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    letter-spacing: 0;
  }

  .profitslocal-funnel a {
    color: inherit;
  }

  .pl-header,
  .pl-footer,
  .profitslocal-funnel main {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .pl-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(23, 18, 14, 0.12);
  }

  .pl-brand {
    display: grid;
    gap: 0.1rem;
    text-decoration: none;
  }

  .pl-brand span {
    font-size: 1.15rem;
    font-weight: 950;
    line-height: 1;
  }

  .pl-brand small,
  .pl-project-label {
    color: #8a7460;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pl-header nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.35rem;
  }

  .pl-header nav a {
    min-height: 38px;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(23, 18, 14, 0.14);
    border-radius: 999px;
    padding: 0 0.85rem;
    background: rgba(255, 255, 255, 0.68);
    color: #34261d;
    font-size: 0.85rem;
    font-weight: 850;
    text-decoration: none;
  }

  .profitslocal-funnel main {
    padding: clamp(2rem, 5vw, 4rem) 0;
  }

  .pl-project-label {
    margin: 0 0 1.25rem;
  }

  .pl-footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgba(23, 18, 14, 0.12);
    padding: 1.4rem 0 2rem;
    color: #665d55;
    font-size: 0.9rem;
  }

  .pl-footer span {
    color: #17120e;
    font-weight: 950;
  }

  .pl-footer p {
    max-width: 620px;
    margin: 0;
    text-align: right;
    line-height: 1.55;
  }

  @media (max-width: 760px) {
    .pl-header {
      display: grid;
      align-items: start;
    }

    .pl-header nav {
      justify-content: flex-start;
    }

    .pl-footer {
      display: grid;
    }

    .pl-footer p {
      text-align: left;
    }
  }
</style>
