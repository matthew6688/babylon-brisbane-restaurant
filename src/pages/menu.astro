---
import Layout from '../layouts/Layout.astro';
import { loadRestaurantContent, loadRestaurantDesign, paletteVars } from '../lib/restaurantArtifacts';

const content = loadRestaurantContent();
const design = loadRestaurantDesign();
const styles = paletteVars(design);
const sections = content.menu?.sections || [];
const sourceUrl = content.menu?.sourceUrl || '';
---

<Layout title={'Menu - ' + content.hero.name} description={'Official menu preview for ' + content.hero.name} brandName={content.hero.name} showSalesBar={false} showChrome={false}>
  <section class="menu-app" style={styles}>
    <header class="menu-bar">
      <div>
        <p>Menu</p>
        <h1>{content.hero.name}</h1>
      </div>
      {content.cta.callUrl && <a href={content.cta.callUrl}>Call</a>}
    </header>

    <div class="quick-actions" aria-label="Restaurant actions">
      {content.cta.reserveUrl && <a href={content.cta.reserveUrl}>Reserve</a>}
      {content.cta.mapUrl && <a href={content.cta.mapUrl}>Map</a>}
      {sourceUrl && <a href={sourceUrl}>Source</a>}
    </div>

    <div class="section-list">
      {sections.map((section: any) => (
        <section class="menu-section">
          <div class="section-title">
            <h2>{section.name}</h2>
            {section.description && <p>{section.description}</p>}
          </div>
          <div class="items">
            {(section.items || []).map((item: any) => (
              <article class="menu-item">
                <div>
                  <h3>{item.name}</h3>
                  {item.description && <p>{item.description}</p>}
                </div>
                {item.price && <strong>{item.price}</strong>}
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>

    {!sections.length && (
      <section class="empty-state">
        <h2>Menu artifact required</h2>
        <p>Add a validated content.restaurant.json file with menu.sections before sending this preview.</p>
      </section>
    )}

    <footer class="menu-footer">
      {content.contact.address && <a href={content.cta.mapUrl || undefined}>{content.contact.address}</a>}
      {content.contact.phone && <a href={content.cta.callUrl || undefined}>{content.contact.phone}</a>}
    </footer>
  </section>
</Layout>

<style>
  .menu-app {
    max-width: 560px;
    margin: 0 auto;
    color: var(--wj-ink);
  }

  .menu-bar {
    position: sticky;
    z-index: 10;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid #e6ded4;
    padding: 0.85rem 0;
    background: rgba(251, 250, 247, 0.94);
    backdrop-filter: blur(16px);
  }

  .menu-bar p {
    color: var(--wj-accent);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .menu-bar h1 {
    margin-top: 0.1rem;
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0;
  }

  .menu-bar a,
  .quick-actions a {
    color: var(--wj-ink);
    font-size: 0.86rem;
    font-weight: 900;
    text-decoration: none;
  }

  .menu-bar a {
    border: 1px solid #ddd6cc;
    border-radius: 999px;
    padding: 0.55rem 0.85rem;
    background: white;
  }

  .quick-actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.45rem;
    padding: 0.85rem 0 1.15rem;
  }

  .quick-actions a {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--wj-ink);
    color: white;
  }

  .quick-actions a:nth-child(2),
  .quick-actions a:nth-child(3) {
    background: #fff;
    color: var(--wj-ink);
    border: 1px solid #ddd6cc;
  }

  .section-list {
    display: grid;
    gap: 0;
  }

  .menu-section {
    display: grid;
    gap: 0.9rem;
    border-bottom: 1px solid #ddd6cc;
    padding: 1.35rem 0 1.5rem;
  }

  .section-title h2 {
    font-size: 1.3rem;
    font-weight: 900;
  }

  .section-title p {
    margin-top: 0.35rem;
    color: var(--wj-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .items {
    display: grid;
    gap: 0;
    border-top: 1px solid #e6ded4;
  }

  .menu-item {
    display: flex;
    min-height: 140px;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid #e6ded4;
    padding: 1rem 0;
    background: transparent;
  }

  .menu-item h3 {
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.35;
  }

  .menu-item p {
    margin-top: 0.7rem;
    color: #675c52;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .menu-item strong {
    color: var(--wj-accent);
    font-weight: 900;
    white-space: nowrap;
  }

  .empty-state {
    margin-top: 1rem;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .empty-state {
    background: #fff7ed;
  }

  .menu-footer {
    display: grid;
    gap: 0.35rem;
    padding: 1.2rem 0 0;
    color: #675c52;
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .menu-footer a {
    color: inherit;
    font-weight: 900;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (min-width: 820px) {
    .items {
      grid-template-columns: 1fr;
    }
  }
</style>
