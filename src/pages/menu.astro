---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';
import { restaurantData } from '../data/restaurant';
---

<Layout title={'Menu | ' + siteConfig.name} description={'Real menu highlights for ' + siteConfig.name}>
  <section class="-mx-6 -mt-12 border-b border-stone-200 bg-stone-100 px-6 py-14 md:rounded-b-[2rem] md:px-12">
    <div class="max-w-5xl">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-amber-700">Verified Menu</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight text-stone-950 md:text-7xl">{siteConfig.name}</h1>
      <p class="mt-5 max-w-3xl text-xl leading-8 text-stone-700">{restaurantData.cuisine}. Menu sections below are drawn from the public source linked on this page.</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm font-bold">
        <a href={restaurantData.menuSourceUrl} target="_blank" rel="noreferrer" class="rounded-full bg-stone-950 px-5 py-3 text-white">Open source menu</a>
        <a href={restaurantData.bookingUrl} target="_blank" rel="noreferrer" class="rounded-full border border-stone-300 px-5 py-3 text-stone-950">Book / enquire</a>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="grid gap-8 lg:grid-cols-3">
      {restaurantData.sections.map((section, index) => (
        <article class:list={["overflow-hidden rounded-3xl border border-stone-200 bg-white shadow-sm", index === 0 && "lg:col-span-2"]}>
          <div class="border-b border-stone-200 bg-stone-950 p-6 text-white">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-300">0{index + 1}</p>
            <h2 class="mt-2 text-3xl font-black">{section.title}</h2>
            <p class="mt-2 text-sm leading-6 text-stone-300">{section.note}</p>
          </div>
          <div class="divide-y divide-stone-100">
            {section.items.map((item) => (
              <div class="grid gap-3 p-6 sm:grid-cols-[1fr_auto]">
                <div>
                  <h3 class="text-xl font-black text-stone-950">{item.name}</h3>
                  <p class="mt-2 leading-7 text-stone-600">{item.description}</p>
                </div>
                {item.price && <div class="text-lg font-black text-amber-700">{item.price}</div>}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="rounded-3xl bg-amber-100 p-8 text-stone-950">
    <p class="text-sm font-bold uppercase tracking-[0.2em] text-amber-800">Data Source</p>
    <p class="mt-3 max-w-3xl text-lg leading-8">Menu content is based on <a href={restaurantData.menuSourceUrl} target="_blank" rel="noreferrer" class="font-bold underline underline-offset-4">{restaurantData.menuSourceLabel}</a>. Prices and availability can change, so final client delivery should re-scrape immediately before outreach.</p>
  </section>
</Layout>
