---
import Layout from '../layouts/Layout.astro';
import { restaurantData as d } from '../data/restaurant';
const tel = d.phone ? 'tel:' + d.phone.replace(/[^+0-9]/g, '') : undefined;
const mail = d.email ? 'mailto:' + d.email : undefined;
const featured = d.sections.flatMap((s) => s.items.slice(0, 2)).slice(0, 6);
---
<Layout title={(`Menu | ` + d.name).trim()} description={d.cuisine}>
  <div style={'--bg:'+d.brand.bg+';--paper:'+d.brand.paper+';--ink:'+d.brand.ink+';--muted:'+d.brand.muted+';--accent:'+d.brand.accent+';--accent2:'+d.brand.accent2} class="-mx-6 -mt-12 min-h-screen bg-[var(--paper)] text-[var(--ink)] md:rounded-b-[2rem]">
    <section class="grid gap-8 p-5 md:p-10 lg:grid-cols-[0.82fr_1.18fr]">
      <div class="lg:sticky lg:top-8 lg:self-start">
        <div class="mb-5 inline-flex rounded-full border border-black/10 bg-white/55 px-4 py-2 text-xs font-black uppercase tracking-[0.2em] text-[var(--accent)]">Google Places + official menu</div>
        <img src={d.logoImage} alt={d.name + ' logo'} class:list={["mb-6 max-h-24 max-w-[260px] object-contain", d.brand.logoInvert && "rounded-xl bg-[var(--bg)] p-4"]} />
        <h1 class="max-w-3xl text-5xl font-black leading-[0.9] tracking-tight md:text-7xl">{d.name}</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--muted)] md:text-xl">{d.cuisine}</p>
        <div class="mt-7 flex flex-wrap gap-3"><a href="/menu" class="rounded-full bg-[var(--bg)] px-6 py-3 text-sm font-black text-white">Menu</a><a href={d.bookingUrl} target="_blank" class="rounded-full bg-[var(--accent)] px-6 py-3 text-sm font-black text-white">Reserve</a>{tel && <a href={tel} class="rounded-full border border-black/15 px-6 py-3 text-sm font-black">Call</a>}<a href={d.googleMapsUrl} target="_blank" class="rounded-full border border-black/15 px-6 py-3 text-sm font-black">Navigate</a></div>
        <img src={d.heroImage} alt={d.name + ' venue photo'} class="mt-8 h-72 w-full rounded-3xl object-cover shadow-xl" />
      </div>
      <div class="space-y-5">
        {d.sections.map((section, index) => (<article class="overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-black/5"><div class="bg-[var(--bg)] p-6 text-white"><p class="text-xs font-black uppercase tracking-[0.2em] text-[var(--accent2)]">0{index + 1}</p><h2 class="mt-2 text-3xl font-black">{section.title}</h2><p class="mt-2 text-white/65">{section.note}</p></div><div class="divide-y divide-stone-100">{section.items.map((item) => (<div class="grid gap-3 p-5 sm:grid-cols-[1fr_auto]"><div><h3 class="text-xl font-black">{item.name}</h3><p class="mt-2 leading-7 text-stone-600">{item.description}</p></div><strong class="text-lg text-[var(--accent)]">{item.price}</strong></div>))}</div></article>))}
      </div>
    </section>
    <section class="grid gap-3 p-5 pb-24 md:grid-cols-3 md:p-10"><a href={d.menuSourceUrl} target="_blank" class="rounded-2xl bg-white/70 p-5 font-bold shadow-sm">Source: {d.menuSourceLabel}</a><a href={d.website} target="_blank" class="rounded-2xl bg-white/70 p-5 font-bold shadow-sm">Official website</a>{d.email && <a href={'mailto:' + d.email} class="rounded-2xl bg-white/70 p-5 font-bold shadow-sm">Email {d.email}</a>}<a href={d.googleMapsUrl} target="_blank" class="rounded-2xl bg-white/70 p-5 font-bold shadow-sm">Navigate to {d.address}</a></section>
    <div class="fixed inset-x-3 bottom-3 z-50 flex gap-2 rounded-full bg-[var(--bg)] p-2 shadow-2xl md:hidden"><a href={tel} class="flex-1 rounded-full bg-white px-4 py-3 text-center text-sm font-black text-[var(--ink)]">Call</a><a href={d.bookingUrl} target="_blank" class="flex-1 rounded-full bg-[var(--accent)] px-4 py-3 text-center text-sm font-black text-white">Reserve</a><a href={d.googleMapsUrl} target="_blank" class="flex-1 rounded-full border border-white/20 px-4 py-3 text-center text-sm font-black text-white">Map</a></div>
  </div>
</Layout>