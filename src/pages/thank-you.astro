---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../config/site';

const clientSlug = Astro.url.searchParams.get('client_slug') || '';
const repo = Astro.url.searchParams.get('repo') || '';
const previewUrl = Astro.url.searchParams.get('preview_url') || (clientSlug ? `https://${clientSlug}-dev.pages.dev` : '');
const tier = Astro.url.searchParams.get('tier') || '';
const domain = Astro.url.searchParams.get('domain') || Astro.url.searchParams.get('preferred_domain') || '';
const email = Astro.url.searchParams.get('email') || '';
const orderId = Astro.url.searchParams.get('order') || Astro.url.searchParams.get('submissionId') || '';
const feedbackUrl = Astro.url.searchParams.get('feedback_url') || '';

function packageLabel(value: string) {
  if (value === 'one_time') return '$399 one-time website with 3 revisions';
  if (value === 'yearly_maintenance') return '$799/year website with monthly maintenance';
  return value;
}
---

<Layout title={`Thank You - ${siteConfig.name}`} description="Order confirmation">
  <section class="thank-you-shell">
    <p class="eyebrow">Payment received</p>
    <h1>Thanks. Your website request is in the queue.</h1>
    <p class="lede">
      We will review the order, prepare the next dev preview, and send you a review link before anything goes live.
    </p>

    <div class="summary-grid">
      {clientSlug && <div><span>Preview</span><a href={previewUrl} target="_blank">{previewUrl}</a></div>}
      {repo && <div><span>Project</span><strong>{repo}</strong></div>}
      {tier && <div><span>Package</span><strong>{packageLabel(tier)}</strong></div>}
      {orderId && <div><span>Order</span><strong>{orderId}</strong></div>}
    </div>

    <div class="next-grid">
      <article>
        <span>01</span>
        <h2>Choose your domain route</h2>
        <p>
          Use your root domain, for example <strong>yourbusiness.com</strong>, or use a subdomain like
          <strong> menu.yourbusiness.com</strong>. If you already entered a domain, we will use that as the starting point.
        </p>
        {domain && <p class="note">Submitted domain: <strong>{domain}</strong></p>}
      </article>

      <article>
        <span>02</span>
        <h2>Prepare DNS access</h2>
        <p>
          If your domain is on Cloudflare, add us as a temporary collaborator or send the zone details.
          Otherwise, we will send exact DNS records for your registrar.
        </p>
      </article>

      <article>
        <span>03</span>
        <h2>Send revisions before launch</h2>
        <p>
          Reply with content edits, new photos, logo files, menu updates, or design notes. One-time websites include
          3 revision rounds; yearly maintenance includes monthly updates.
        </p>
        {feedbackUrl && <a class="action-link" href={feedbackUrl}>Submit revision request</a>}
      </article>

      <article>
        <span>04</span>
        <h2>Approve the dev preview</h2>
        <p>
          We update the dev preview first. Once you approve it, we connect the live domain and send the final link.
        </p>
      </article>
    </div>

    <div class="contact-panel">
      <h2>Need to add something?</h2>
      <p>
        {email ? `We will contact ${email}. ` : ''}
        You can also email us directly with assets, domain notes, or urgent changes.
      </p>
      <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
    </div>
  </section>
</Layout>

<style>
  .thank-you-shell {
    max-width: 980px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .eyebrow,
  .next-grid article > span {
    color: #b9802f;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 820px;
    margin-top: 0.8rem;
    color: #17120e;
    font-size: clamp(3rem, 8vw, 6.8rem);
    font-weight: 950;
    line-height: 0.9;
    letter-spacing: 0;
  }

  .lede {
    max-width: 660px;
    margin-top: 1.4rem;
    color: #665d55;
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    margin-top: 3rem;
    background: #ddd6cc;
    border: 1px solid #ddd6cc;
  }

  .summary-grid div {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
    padding: 1rem;
    background: white;
  }

  .summary-grid span {
    color: #84786d;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .summary-grid a,
  .summary-grid strong {
    overflow-wrap: anywhere;
    color: #17120e;
    font-weight: 900;
  }

  .next-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
    margin-top: 3rem;
  }

  .next-grid article,
  .contact-panel {
    border: 1px solid #ddd6cc;
    padding: clamp(1.25rem, 3vw, 2rem);
    background: #fff;
  }

  .next-grid h2,
  .contact-panel h2 {
    margin-top: 0.7rem;
    color: #17120e;
    font-size: 1.35rem;
    font-weight: 950;
  }

  .next-grid p,
  .contact-panel p {
    margin-top: 0.8rem;
    color: #665d55;
    line-height: 1.7;
  }

  .note {
    border-top: 1px solid #eee7de;
    padding-top: 0.9rem;
  }

  .action-link,
  .contact-panel a {
    display: inline-flex;
    margin-top: 1rem;
    color: #17120e;
    font-weight: 950;
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .contact-panel {
    margin-top: 1.2rem;
    background: #17120e;
    color: white;
  }

  .contact-panel h2,
  .contact-panel a {
    color: white;
  }

  .contact-panel p {
    color: rgba(255, 255, 255, 0.72);
  }

  @media (max-width: 720px) {
    .summary-grid,
    .next-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
