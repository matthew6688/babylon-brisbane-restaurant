---
import Layout from '../layouts/Layout.astro';
import { restaurantData as d } from '../data/restaurant';
const tel = d.phone ? 'tel:' + d.phone.replace(/[^+0-9]/g, '') : undefined;
const mail = d.email ? 'mailto:' + d.email : undefined;
const featured = d.sections.flatMap((s) => s.items.slice(0, 2)).slice(0, 6);
---
<Layout title={(` ` + d.name).trim()} description={d.cuisine}>
  <div style={'--bg:'+d.brand.bg+';--paper:'+d.brand.paper+';--ink:'+d.brand.ink+';--muted:'+d.brand.muted+';--accent:'+d.brand.accent+';--accent2:'+d.brand.accent2} class="-mx-6 -mt-12 min-h-screen bg-[var(--paper)] text-[var(--ink)] md:rounded-b-[2rem]">
    <section class="grid gap-8 p-5 md:p-10 lg:min-h-[82vh] lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div class="order-2 lg:order-1">
        <div class="mb-5 inline-flex rounded-full border border-black/10 bg-white/55 px-4 py-2 text-xs font-black uppercase tracking-[0.2em] text-[var(--accent)]">Google Places + official menu</div>
        <img src={d.logoImage} alt={d.name + ' logo'} class:list={["mb-6 max-h-24 max-w-[260px] object-contain", d.brand.logoInvert && "rounded-xl bg-[var(--bg)] p-4"]} />
        <h1 class="max-w-3xl text-5xl font-black leading-[0.9] tracking-tight md:text-7xl">{d.name}</h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-[var(--muted)] md:text-xl">{d.cuisine}</p>
        <div class="mt-7 flex flex-wrap gap-3"><a href="/menu" class="rounded-full bg-[var(--bg)] px-6 py-3 text-sm font-black text-white">Menu</a><a href={d.bookingUrl} target="_blank" class="rounded-full bg-[var(--accent)] px-6 py-3 text-sm font-black text-white">Reserve</a>{tel && <a href={tel} class="rounded-full border border-black/15 px-6 py-3 text-sm font-black">Call</a>}<a href={d.googleMapsUrl} target="_blank" class="rounded-full border border-black/15 px-6 py-3 text-sm font-black">Navigate</a></div>
        
      </div>
      <div class="order-1 grid h-[520px] grid-cols-6 grid-rows-6 gap-3 lg:order-2">
        <img src={d.heroImage} alt={d.name + ' hero'} class="col-span-6 row-span-4 h-full w-full rounded-[2rem] object-cover shadow-2xl" />{d.galleryImages.slice(0,3).map((img) => <img src={img} alt={d.name + ' photo'} class="col-span-2 row-span-2 h-full w-full rounded-2xl object-cover shadow-lg" />)}
      </div>
    </section>
    <section class="grid gap-4 px-5 pb-10 md:grid-cols-4 md:px-10"><a href={d.googleMapsUrl} target="_blank" class="rounded-2xl bg-white/65 p-5 shadow-sm"><span class="block text-xs font-black uppercase tracking-widest text-[var(--accent)]">Address</span><strong class="mt-2 block">{d.address}</strong></a><a href={tel} class="rounded-2xl bg-white/65 p-5 shadow-sm"><span class="block text-xs font-black uppercase tracking-widest text-[var(--accent)]">Phone</span><strong class="mt-2 block">{d.phone}</strong></a>{mail ? <a href={mail} class="rounded-2xl bg-white/65 p-5 shadow-sm"><span class="block text-xs font-black uppercase tracking-widest text-[var(--accent)]">Email</span><strong class="mt-2 block break-all">{d.email}</strong></a> : <a href={d.website} target="_blank" class="rounded-2xl bg-white/65 p-5 shadow-sm"><span class="block text-xs font-black uppercase tracking-widest text-[var(--accent)]">Website</span><strong class="mt-2 block">Official site</strong></a>}<div class="rounded-2xl bg-white/65 p-5 shadow-sm"><span class="block text-xs font-black uppercase tracking-widest text-[var(--accent)]">Rating</span><strong class="mt-2 block">{d.rating}/5 · {d.reviewCount} reviews</strong></div></section><section class="p-5 md:p-10"><h2 class="text-4xl font-black">Real menu highlights</h2><div class="mt-6 grid gap-4 md:grid-cols-3">{featured.map((item) => <article class="rounded-2xl bg-white p-5 shadow-sm"><div class="flex justify-between gap-4"><h3 class="text-lg font-black">{item.name}</h3><span class="font-black text-[var(--accent)]">{item.price}</span></div><p class="mt-3 text-stone-600">{item.description}</p></article>)}</div></section>
    <div class="fixed inset-x-3 bottom-3 z-50 flex gap-2 rounded-full bg-[var(--bg)] p-2 shadow-2xl md:hidden"><a href={tel} class="flex-1 rounded-full bg-white px-4 py-3 text-center text-sm font-black text-[var(--ink)]">Call</a><a href={d.bookingUrl} target="_blank" class="flex-1 rounded-full bg-[var(--accent)] px-4 py-3 text-center text-sm font-black text-white">Reserve</a><a href={d.googleMapsUrl} target="_blank" class="flex-1 rounded-full border border-white/20 px-4 py-3 text-center text-sm font-black text-white">Map</a></div>
  </div>
</Layout>