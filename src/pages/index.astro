---
import Layout from '../layouts/Layout.astro';
import {
  firstImage,
  loadRestaurantContent,
  loadRestaurantDesign,
  paletteVars,
  supportingImages,
} from '../lib/restaurantArtifacts';

const content = loadRestaurantContent();
const design = loadRestaurantDesign();
const styles = paletteVars(design);
const heroImage = firstImage(content);
const supportImages = supportingImages(content);
const sections = content.menu?.sections || [];
const menuItems = sections.flatMap((section: any) => section.items || []);
const featuredItems = menuItems.slice(0, 6);
const logo = content.brand?.logo || '';
const cuisine = content.hero.cuisine || 'restaurant';
const rating = content.hero.rating ? String(content.hero.rating) : 'Verified';
const reviewCount = content.hero.reviewCount ? `${content.hero.reviewCount.toLocaleString()}+` : 'Google';
const menuCount = menuItems.length ? `${menuItems.length}+` : 'Curated';
const addressShort = content.contact.address?.split(',').slice(0, 2).join(',') || 'Brisbane';
const proofItems = [
  { value: rating, label: 'Google rating' },
  { value: reviewCount, label: 'Guest signals' },
  { value: menuCount, label: 'Menu items' },
  { value: content.cta.reserveUrl ? 'Reserve' : 'Call', label: 'Direct booking' },
];
const serviceCards = [
  {
    eyebrow: '01',
    title: 'Dining room',
    copy: `A composed ${cuisine} experience in the heart of Brisbane, shaped for relaxed lunches, dinners, and celebrations.`,
    image: supportImages[0] || heroImage,
  },
  {
    eyebrow: '02',
    title: 'Seasonal menu',
    copy: 'Share plates, signatures, and mains presented with clear pricing so guests can choose before they arrive.',
    image: supportImages[1] || heroImage,
  },
  {
    eyebrow: '03',
    title: 'Reservations',
    copy: 'Direct booking, phone, and map links make the next step simple from desktop or mobile.',
    image: supportImages[2] || heroImage,
  },
];
const trustItems = [
  { title: 'Central Brisbane location', copy: content.contact.address || 'A convenient city address for lunch, dinner, and private celebrations.' },
  { title: 'Guest confidence', copy: content.hero.reviewCount ? `${content.hero.reviewCount.toLocaleString()} Google reviews with a ${rating}/5 rating.` : 'Clear contact details and direct booking for guest confidence.' },
  { title: 'Menu before arrival', copy: 'A mobile-friendly menu keeps dishes, descriptions, and prices easy to scan.' },
];
---

<Layout title={content.hero.name + ' Official Preview'} description={content.hero.tagline} brandName={content.hero.name} fullBleed>
  <div class="site-shell" style={styles}>
    <section class="hero-section">
      {heroImage && <img class="hero-bg" src={heroImage} alt={`${content.hero.name} dining room or food`} />}
      <div class="hero-shade"></div>
      <div class="section-inner hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Brisbane dining</p>
          {logo && <img class="hero-logo" src={logo} alt={`${content.hero.name} logo`} />}
          <h1>{content.hero.name}</h1>
          <p class="hero-subtitle">{content.hero.tagline || `${cuisine} in ${addressShort}`}</p>
          <div class="hero-actions">
            {content.cta.reserveUrl && <a class="button button-primary" href={content.cta.reserveUrl}>Reserve a table</a>}
            {sections.length > 0 && <a class="button button-secondary" href="/menu">View menu</a>}
            {content.cta.callUrl && <a class="text-link" href={content.cta.callUrl}>{content.contact.phone}</a>}
          </div>
        </div>
      </div>
    </section>

    <section class="proof-bar" aria-label="Restaurant proof points">
      <div class="section-inner proof-grid">
        {proofItems.map((item) => (
          <div class="proof-item">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="section-block services-block">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">At the table</p>
          <h2>Modern dining, clear details, easy booking.</h2>
          <span>A polished restaurant website should lead with atmosphere and trust, then make the menu, booking, call, and map paths effortless.</span>
        </div>
        <div class="service-grid">
          {serviceCards.map((card) => (
            <article class="service-card">
              {card.image && <img src={card.image} alt={`${content.hero.name} ${card.title}`} />}
              <div>
                <span>{card.eyebrow}</span>
                <h3>{card.title}</h3>
                <p>{card.copy}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-block story-block">
      <div class="section-inner story-grid">
        <figure class="story-image">
          {supportImages[0] || heroImage
            ? <img src={supportImages[0] || heroImage} alt={`${content.hero.name} atmosphere`} />
            : <div class="image-placeholder">Photo pending</div>}
          <figcaption>
            <strong>{rating}</strong>
            <span>{content.hero.reviewCount ? `${content.hero.reviewCount.toLocaleString()} Google reviews` : 'Google Places evidence'}</span>
          </figcaption>
        </figure>
        <div class="story-copy">
          <p class="eyebrow">Why visit</p>
          <h2>A city dining room with a confident point of view.</h2>
          <p class="lede">
            {content.hero.name} pairs a central Brisbane address with a menu built for sharing, booking links that work, and the practical details guests need before they arrive.
          </p>
          <div class="trust-list">
            {trustItems.map((item) => (
              <div class="trust-item">
                <span>✓</span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.copy}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-block menu-block">
      <div class="section-inner">
        <div class="section-heading section-heading-row">
          <div>
            <p class="eyebrow">Menu highlights</p>
            <h2>Selected from the official menu.</h2>
          </div>
          {sections.length > 0 && <a class="section-link" href="/menu">Open mobile menu</a>}
        </div>
        <div class="menu-grid">
          {featuredItems.map((item: any) => (
            <article class="menu-card">
              <div>
                <h3>{item.name}</h3>
                {item.description && <p>{item.description}</p>}
              </div>
              {item.price && <strong>{item.price}</strong>}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="section-inner cta-inner">
        <p class="eyebrow">Plan a visit</p>
        <h2>{content.hero.name}</h2>
        <p>{content.contact.address || addressShort}</p>
        <div class="cta-actions">
          {content.cta.reserveUrl && <a class="button button-primary" href={content.cta.reserveUrl}>Reserve now</a>}
          {content.cta.mapUrl && <a class="button button-secondary" href={content.cta.mapUrl}>Get directions</a>}
          {content.cta.callUrl && <a class="text-link" href={content.cta.callUrl}>{content.contact.phone}</a>}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .site-shell {
    --page-bg: #fbfaf7;
    --dark: color-mix(in srgb, var(--wj-ink), #101522 28%);
    background: var(--page-bg);
    color: var(--wj-ink);
  }

  .section-inner {
    width: min(100% - 40px, 1180px);
    margin: 0 auto;
  }

  .hero-section {
    position: relative;
    min-height: clamp(620px, 82vh, 860px);
    display: grid;
    align-items: center;
    overflow: hidden;
    background: var(--dark);
    color: white;
  }

  .hero-bg,
  .hero-shade {
    position: absolute;
    inset: 0;
  }

  .hero-bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
  }

  .hero-shade {
    background:
      linear-gradient(90deg, rgba(9, 12, 20, 0.9), rgba(9, 12, 20, 0.5) 48%, rgba(9, 12, 20, 0.18)),
      linear-gradient(0deg, rgba(9, 12, 20, 0.36), rgba(9, 12, 20, 0.18));
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    padding: clamp(5rem, 12vw, 9rem) 0;
  }

  .hero-copy {
    max-width: 720px;
  }

  .eyebrow {
    color: var(--wj-accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-logo {
    display: block;
    width: min(330px, 72vw);
    max-height: 98px;
    object-fit: contain;
    object-position: left center;
    margin: 1.35rem 0 1.6rem;
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.22));
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  .hero-copy h1 {
    max-width: 760px;
    font-size: clamp(4rem, 9vw, 8.9rem);
    line-height: 0.86;
    font-weight: 950;
    letter-spacing: 0;
  }

  .hero-subtitle {
    max-width: 560px;
    margin-top: 1.5rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem;
    margin-top: 2.25rem;
  }

  .button,
  .text-link,
  .section-link {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    font-size: 0.86rem;
    font-weight: 900;
    text-decoration: none;
  }

  .button {
    padding: 0.82rem 1.25rem;
  }

  .button-primary {
    background: var(--wj-accent);
    color: white;
  }

  .button-secondary {
    border: 1px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  .text-link {
    color: currentColor;
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .proof-bar {
    background: #191d25;
    color: white;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .proof-item {
    display: grid;
    gap: 0.35rem;
    justify-items: center;
    padding: 2rem 1rem;
    text-align: center;
  }

  .proof-item strong {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1;
  }

  .proof-item span {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-block {
    padding: clamp(5.5rem, 9vw, 8.5rem) 0;
  }

  .section-heading {
    max-width: 680px;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .section-heading-row {
    max-width: none;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
  }

  .section-heading h2,
  .story-copy h2,
  .cta-inner h2 {
    margin-top: 0.8rem;
    font-size: clamp(2.4rem, 5vw, 5.2rem);
    line-height: 0.98;
    font-weight: 950;
    letter-spacing: 0;
  }

  .section-heading span,
  .lede,
  .cta-inner p {
    display: block;
    max-width: 610px;
    margin-top: 1.25rem;
    color: #665d55;
    font-size: 1rem;
    line-height: 1.75;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .service-card {
    border: 1px solid #e4ddd4;
    background: white;
  }

  .service-card img {
    width: 100%;
    aspect-ratio: 1.32;
    object-fit: cover;
  }

  .service-card div {
    padding: 1.55rem;
  }

  .service-card span {
    color: var(--wj-accent);
    font-size: 0.75rem;
    font-weight: 950;
  }

  .service-card h3 {
    margin-top: 0.7rem;
    font-size: 1.35rem;
    font-weight: 900;
  }

  .service-card p,
  .menu-card p,
  .trust-item p {
    margin-top: 0.8rem;
    color: #665d55;
    line-height: 1.65;
  }

  .story-block {
    background: #f1f3f5;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    gap: clamp(3rem, 8vw, 7rem);
    align-items: center;
  }

  .story-image {
    position: relative;
    min-height: 520px;
  }

  .story-image img,
  .image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 520px;
    object-fit: cover;
  }

  .story-image figcaption {
    position: absolute;
    left: 0;
    bottom: 0;
    min-width: 210px;
    padding: 1.55rem;
    background: var(--dark);
    color: white;
  }

  .story-image strong {
    display: block;
    font-size: 2.15rem;
  }

  .story-image span {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.8rem;
  }

  .trust-list {
    display: grid;
    gap: 1.55rem;
    margin-top: 2rem;
  }

  .trust-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
  }

  .trust-item > span {
    display: grid;
    width: 24px;
    height: 24px;
    place-items: center;
    border-radius: 50%;
    background: var(--wj-accent);
    color: white;
    font-size: 0.72rem;
    font-weight: 900;
  }

  .trust-item h3 {
    font-size: 1rem;
    font-weight: 950;
  }

  .section-link {
    color: var(--wj-ink);
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid #ddd6cc;
    gap: 0 2rem;
  }

  .menu-card {
    display: flex;
    min-height: 176px;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid #ddd6cc;
    padding: 1.45rem 0;
  }

  .menu-card h3 {
    font-size: 1.24rem;
    font-weight: 950;
    line-height: 1.25;
  }

  .menu-card strong {
    color: var(--wj-accent);
    font-weight: 950;
    white-space: nowrap;
  }

  .cta-section {
    padding: clamp(5rem, 9vw, 8rem) 0;
    background: var(--dark);
    color: white;
    text-align: center;
  }

  .cta-inner {
    display: grid;
    justify-items: center;
  }

  .cta-inner p {
    color: rgba(255, 255, 255, 0.72);
  }

  .cta-section .button-secondary {
    border-color: rgba(255, 255, 255, 0.26);
  }

  @media (max-width: 900px) {
    .section-inner {
      width: min(100% - 32px, 680px);
    }

    .hero-section {
      min-height: 680px;
    }

    .hero-shade {
      background: linear-gradient(0deg, rgba(9, 12, 20, 0.92), rgba(9, 12, 20, 0.48));
    }

    .proof-grid,
    .service-grid,
    .story-grid,
    .menu-grid {
      grid-template-columns: 1fr;
    }

    .proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .section-heading-row {
      display: grid;
      align-items: start;
    }

    .story-image,
    .story-image img,
    .image-placeholder {
      min-height: 360px;
    }
  }

  @media (max-width: 560px) {
    .section-inner {
      width: min(100% - 28px, 520px);
    }

    .hero-copy h1 {
      font-size: clamp(3rem, 17vw, 4.7rem);
    }

    .hero-actions,
    .cta-actions {
      align-items: stretch;
    }

    .button,
    .text-link {
      width: 100%;
    }

    .proof-item {
      padding: 1.35rem 0.5rem;
    }
  }
</style>
