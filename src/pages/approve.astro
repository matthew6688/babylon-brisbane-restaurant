---
import Layout from '../layouts/Layout.astro';
import { loadCheckoutArtifact, loadRestaurantContent } from '../lib/restaurantArtifacts';

const content = loadRestaurantContent();
const checkout = loadCheckoutArtifact();
---

<Layout title={`Approve Preview - ${content.hero.name}`} description="Approve the dev preview for live publishing">
  <section class="approve-shell">
    <p class="eyebrow">Launch approval</p>
    <h1>Approve the dev preview.</h1>
    <p class="lede">Use the same Order ID and checkout email. After approval, we publish the reviewed dev version to the live site and email the final link.</p>

    <form class="approve-form" data-approve-form>
      <input type="hidden" name="client_slug" value={checkout.hiddenFields?.client_slug || checkout.clientSlug || ''} />
      <input type="hidden" name="repo" value={checkout.hiddenFields?.repo || ''} />

      <label>
        Order ID
        <input name="order_id" required placeholder="cs_test_..." autocomplete="off" />
      </label>

      <label>
        Checkout email
        <input name="email" type="email" required placeholder="owner@example.com" />
      </label>

      <label class="wide confirm-row">
        <input name="confirm" type="checkbox" required value="yes" />
        <span>I approve this dev preview for live publishing.</span>
      </label>

      <button type="submit">Approve and publish live</button>
      <p class="status" data-status></p>
    </form>
  </section>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const form = document.querySelector('[data-approve-form]');
  const status = document.querySelector('[data-status]');
  const prefill = {
    order_id: params.get('order_id') || params.get('session_id') || '',
    email: params.get('email') || '',
  };
  for (const [name, value] of Object.entries(prefill)) {
    if (value && form?.elements?.[name]) form.elements[name].value = value;
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    status.textContent = 'Submitting approval...';
    const payload = Object.fromEntries(new FormData(form).entries());
    const response = await fetch('/api/approval-request/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await response.json();
    if (!response.ok) {
      status.textContent = data.error || 'Approval failed.';
      return;
    }
    status.textContent = 'Approval received. We are publishing the live site and will email the final link.';
    form.reset();
  });
</script>

<style>
  .approve-shell {
    max-width: 860px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .eyebrow {
    color: #b9802f;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin-top: 0.8rem;
    color: #17120e;
    font-size: clamp(3rem, 8vw, 6.2rem);
    font-weight: 950;
    line-height: 0.9;
  }

  .lede {
    max-width: 680px;
    margin-top: 1.2rem;
    color: #665d55;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .approve-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
    border: 1px solid #ddd6cc;
    padding: clamp(1rem, 3vw, 2rem);
    background: white;
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: #17120e;
    font-weight: 900;
  }

  .wide,
  button,
  .status {
    grid-column: 1 / -1;
  }

  .confirm-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .confirm-row input {
    width: 18px;
    height: 18px;
  }

  input {
    width: 100%;
    border: 1px solid #ddd6cc;
    border-radius: 4px;
    padding: 0.82rem 0.9rem;
    color: #17120e;
    font: inherit;
    font-weight: 600;
  }

  button {
    min-height: 52px;
    border: 0;
    border-radius: 4px;
    background: #17120e;
    color: white;
    font-weight: 950;
    cursor: pointer;
  }

  .status {
    margin: 0;
    color: #665d55;
    font-weight: 800;
  }

  @media (max-width: 720px) {
    .approve-form {
      grid-template-columns: 1fr;
    }
  }
</style>
