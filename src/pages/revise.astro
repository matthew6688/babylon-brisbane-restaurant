---
import Layout from '../layouts/Layout.astro';
import { loadCheckoutArtifact, loadRestaurantContent } from '../lib/restaurantArtifacts';

const content = loadRestaurantContent();
const checkout = loadCheckoutArtifact();
---

<Layout title={`Request Revisions - ${content.hero.name}`} description="Submit website revision request">
  <section class="revise-shell">
    <p class="eyebrow">Revision request</p>
    <h1>{content.hero.name}</h1>
    <p class="lede">We match your Stripe order ID and checkout email before creating a revision task. When you open this page from your preview email, those two fields are locked so the task stays attached to the right order.</p>

    <div class="order-card" data-order-card hidden>
      <div>
        <span>Order status</span>
        <strong data-order-title>Checking...</strong>
      </div>
      <dl>
        <div>
          <dt>Revisions</dt>
          <dd data-revision-usage>-</dd>
        </div>
        <div>
          <dt>Remaining</dt>
          <dd data-revision-remaining>-</dd>
        </div>
        <div>
          <dt>Plan</dt>
          <dd data-plan>-</dd>
        </div>
      </dl>
      <p data-reset hidden></p>
    </div>

    <form class="revise-form" data-revise-form>
      <input type="hidden" name="client_slug" value={checkout.hiddenFields?.client_slug || checkout.clientSlug || ''} />
      <input type="hidden" name="repo" value={checkout.hiddenFields?.repo || ''} />
      <input type="hidden" name="template" value={checkout.hiddenFields?.template || 'webjuice-restaurant'} />
      <input type="hidden" name="preview_url" value={checkout.hiddenFields?.preview_url || ''} />

      <label>
        Order ID
        <input name="order_id" required placeholder="cs_test_..." autocomplete="off" data-lockable />
      </label>

      <label>
        Checkout email
        <input name="email" type="email" required placeholder="owner@example.com" data-lockable />
      </label>

      <label class="wide">
        Requested changes
        <textarea name="requested_changes" required rows="7" placeholder="List the exact copy, menu, photo, domain, or design changes you want us to make."></textarea>
      </label>

      <label class="wide">
        Reference URL or asset link
        <input name="reference_url" placeholder="Google Drive, Dropbox, website URL, or image link" />
      </label>

      <label class="wide">
        Attach files
        <input name="attachments" type="file" multiple accept="image/*,.pdf,.doc,.docx,.txt,.md,.csv,.xls,.xlsx,.ppt,.pptx" data-attachments />
        <span class="hint">Photos, menus, PDFs, documents, or screenshots. Use the change notes to tell us where each file should be used.</span>
      </label>

      <div class="attachment-list wide" data-attachment-list hidden></div>

      <button class="secondary" type="button" data-check-status>Check remaining revisions</button>
      <button type="submit">Submit revision request</button>
      <a class="extra-link" data-extra-link>Buy extra revision - $100</a>
      <p class="status" data-status></p>
    </form>
  </section>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  const form = document.querySelector('[data-revise-form]');
  const status = document.querySelector('[data-status]');
  const orderCard = document.querySelector('[data-order-card]');
  const orderTitle = document.querySelector('[data-order-title]');
  const revisionUsage = document.querySelector('[data-revision-usage]');
  const revisionRemaining = document.querySelector('[data-revision-remaining]');
  const plan = document.querySelector('[data-plan]');
  const reset = document.querySelector('[data-reset]');
  const checkStatus = document.querySelector('[data-check-status]');
  const attachmentInput = document.querySelector('[data-attachments]');
  const attachmentList = document.querySelector('[data-attachment-list]');
  const prefill = {
    order_id: params.get('order_id') || params.get('session_id') || '',
    email: params.get('email') || '',
  };
  for (const [name, value] of Object.entries(prefill)) {
    if (value && form?.elements?.[name]) form.elements[name].value = value;
  }
  if (prefill.order_id && prefill.email) {
    ['order_id', 'email'].forEach((name) => {
      const field = form?.elements?.[name];
      if (!field) return;
      field.readOnly = true;
      field.setAttribute('aria-readonly', 'true');
      field.dataset.locked = 'true';
    });
  }
  const extraLink = document.querySelector('[data-extra-link]');
  if (extraLink) {
    const checkout = new URL('/checkout', window.location.origin);
    checkout.searchParams.set('tier', 'extra_revision');
    if (prefill.order_id) checkout.searchParams.set('order_id', prefill.order_id);
    if (prefill.email) checkout.searchParams.set('email', prefill.email);
    extraLink.href = checkout.toString();
  }

  async function loadOrderStatus() {
    const payload = Object.fromEntries(new FormData(form).entries());
    if (!payload.order_id || !payload.email) {
      status.textContent = 'Enter your Order ID and checkout email to check remaining revisions.';
      return;
    }
    orderCard.hidden = false;
    orderTitle.textContent = 'Checking...';
    status.textContent = '';
    const response = await fetch('/api/order-status/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await response.json();
    if (!response.ok) {
      orderTitle.textContent = data.error || 'Order not found';
      revisionUsage.textContent = '-';
      revisionRemaining.textContent = '-';
      plan.textContent = '-';
      reset.hidden = true;
      return;
    }
    const used = data.revision?.used ?? 0;
    const limit = data.revision?.limit ?? 0;
    const remaining = data.revision?.remaining ?? 0;
    orderTitle.textContent = data.case?.status ? data.case.status.replaceAll('_', ' ') : 'Active order';
    revisionUsage.textContent = `${used}/${limit}`;
    revisionRemaining.textContent = String(remaining);
    plan.textContent = labelTier(data.order?.tier);
    if (data.revision?.periodEnd) {
      reset.hidden = false;
      reset.textContent = `Next monthly maintenance reset: ${new Date(data.revision.periodEnd).toLocaleDateString()}`;
    } else {
      reset.hidden = true;
    }
    if (data.links?.extraRevision && extraLink) extraLink.href = data.links.extraRevision;
  }

  function labelTier(value) {
    if (value === 'one_time') return '$399 one-time';
    if (value === 'yearly_maintenance') return '$799 yearly';
    if (value === 'extra_revision') return '$100 extra revision';
    return value || '-';
  }

  checkStatus?.addEventListener('click', loadOrderStatus);
  if (prefill.order_id && prefill.email) loadOrderStatus();

  attachmentInput?.addEventListener('change', () => {
    const files = Array.from(attachmentInput.files || []);
    if (!attachmentList) return;
    if (!files.length) {
      attachmentList.hidden = true;
      attachmentList.innerHTML = '';
      return;
    }
    attachmentList.hidden = false;
    attachmentList.innerHTML = files.map((file, index) => `
      <div>
        <strong>${index + 1}. ${escapeHtml(file.name)}</strong>
        <span>${escapeHtml(file.type || 'file')} · ${formatBytes(file.size)}</span>
      </div>
    `).join('');
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    status.textContent = 'Submitting revision request...';
    const payload = Object.fromEntries(new FormData(form).entries());
    const attachments = Array.from(attachmentInput?.files || []).map((file) => ({
      name: file.name,
      type: file.type || 'file',
      size: file.size,
    }));
    if (attachments.length) {
      payload.attachments = attachments;
      payload.attachment_summary = attachments
        .map((file, index) => `${index + 1}. ${file.name} (${file.type}, ${formatBytes(file.size)})`)
        .join('\n');
    }
    const response = await fetch('/api/revision-request/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await response.json();
    if (!response.ok) {
      status.textContent = data.error || 'Revision request failed.';
      return;
    }
    status.textContent = 'Revision request received. We will match your order ID and checkout email before creating the task.';
    form.reset();
    if (attachmentList) {
      attachmentList.hidden = true;
      attachmentList.innerHTML = '';
    }
  });

  function formatBytes(value) {
    const bytes = Number(value || 0);
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
  }

  function escapeHtml(value) {
    return String(value || '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[char] || char));
  }
</script>

<style>
  .revise-shell {
    max-width: 860px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  .eyebrow {
    color: #b9802f;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin-top: 0.8rem;
    color: #17120e;
    font-size: clamp(3rem, 8vw, 6.2rem);
    font-weight: 950;
    line-height: 0.9;
  }

  .lede {
    max-width: 680px;
    margin-top: 1.2rem;
    color: #665d55;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .revise-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
    border: 1px solid #ddd6cc;
    padding: clamp(1rem, 3vw, 2rem);
    background: white;
  }

  .order-card {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
    border: 1px solid #ddd6cc;
    padding: clamp(1rem, 3vw, 1.5rem);
    background: #f7f2eb;
  }

  .order-card span,
  dt {
    color: #8c6b45;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .order-card strong {
    display: block;
    margin-top: 0.35rem;
    color: #17120e;
    font-size: 1.15rem;
    text-transform: capitalize;
  }

  .order-card dl {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 0;
  }

  .order-card div {
    min-width: 0;
  }

  dd {
    margin: 0.25rem 0 0;
    color: #17120e;
    font-size: 1.05rem;
    font-weight: 950;
  }

  .order-card p {
    margin: 0;
    color: #665d55;
    font-weight: 800;
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: #17120e;
    font-weight: 900;
  }

  .wide,
  button,
  .status {
    grid-column: 1 / -1;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid #ddd6cc;
    border-radius: 4px;
    padding: 0.82rem 0.9rem;
    color: #17120e;
    font: inherit;
    font-weight: 600;
  }

  input[data-locked='true'] {
    background: #f3eee6;
    color: #6c6258;
    cursor: not-allowed;
  }

  input[type='file'] {
    background: #fffdf8;
  }

  .hint {
    color: #766a5f;
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .attachment-list {
    display: grid;
    gap: 0.55rem;
    border: 1px solid #ddd6cc;
    background: #fffdf8;
    padding: 0.85rem;
  }

  .attachment-list div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: #665d55;
    font-size: 0.92rem;
  }

  .attachment-list strong,
  .attachment-list span {
    overflow-wrap: anywhere;
  }

  button {
    min-height: 52px;
    border: 0;
    border-radius: 4px;
    background: #17120e;
    color: white;
    font-weight: 950;
    cursor: pointer;
  }

  .secondary {
    background: #f7f2eb;
    color: #17120e;
    border: 1px solid #ddd6cc;
  }

  .extra-link {
    grid-column: 1 / -1;
    color: #17120e;
    font-weight: 900;
    text-align: center;
    text-underline-offset: 4px;
  }

  .status {
    margin: 0;
    color: #665d55;
    font-weight: 800;
  }

  @media (max-width: 720px) {
    .revise-form {
      grid-template-columns: 1fr;
    }

    .order-card dl {
      grid-template-columns: 1fr;
    }
  }
</style>
